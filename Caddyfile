# Caddy besorgt und erneuert das HTTPS-Zertifikat (Let's Encrypt) automatisch,
# sobald die Domain auf den Server zeigt. Kein Certbot, kein manuelles SSL.

{$DOMAIN} {
	encode zstd gzip
	reverse_proxy app:3000
}

# www-Variante auf die Hauptdomain umleiten
www.{$DOMAIN} {
	redir https://{$DOMAIN}{uri} permanent
}
