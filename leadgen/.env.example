# ── SteelfullAI lead engine ─────────────────────────────────────────────
# Copy to ".env" (repo root or leadgen/) and fill in. Never commit the real .env.

# Where to look + how aggressive to be (keep limits LOW — this is cold B2B).
LEADGEN_LOCATION="Rio de Janeiro, RJ, Brazil"
LEADGEN_DAILY_LIMIT=20
LEADGEN_PER_RUN_LIMIT=10
LEADGEN_MIN_DELAY_MS=8000
LEADGEN_MAX_DELAY_MS=25000

# Channel: "email" (recommended for cold B2B) or "whatsapp"
LEADGEN_CHANNEL=email

# 1) Lead sourcing — Google Places API (Text Search)
#    https://console.cloud.google.com/  -> enable "Places API (New)"
GOOGLE_PLACES_API_KEY=

# 2) Personalization — Claude API (reuses the site key if already set)
ANTHROPIC_API_KEY=
LEADGEN_MODEL=claude-haiku-4-5-20251001

# 3a) Email sending (SMTP — e.g. your Hostinger mailbox)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
OUTREACH_FROM=
OUTREACH_SUBJECT=Uma ideia rápida para o seu negócio

# 3b) WhatsApp sending — pick a provider
WHATSAPP_PROVIDER=evolution          # "cloud" | "evolution"
# Official Meta Cloud API (cold outbound needs an approved template):
WHATSAPP_CLOUD_TOKEN=
WHATSAPP_PHONE_ID=
# Evolution API (self-hosted gateway, common in Brazil):
EVOLUTION_URL=
EVOLUTION_INSTANCE=
EVOLUTION_API_KEY=

# Push collected leads to the private dashboard (/insights/leads)
SITE_URL=https://steelfullai.com
INSIGHTS_USER=               # same basic-auth user as the /insights dashboard
INSIGHTS_PASSWORD=           # the PLAINTEXT password (Caddy stores only the hash)
LEADS_INGEST_SECRET=         # optional extra header check on the ingest endpoint

# Identity injected into the copy
LEADGEN_SENDER_NAME=Tim-Luka Stahl
LEADGEN_SENDER_SITE=https://steelfullai.com
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/tim-luka_stahl
