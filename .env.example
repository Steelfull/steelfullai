# Contact configuration — every CTA on the site reads from these values.
# Copy this file to `.env.local` and fill in real values.

# Calendly scheduling link (primary CTA)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/steelfullai/strategy-call

# WhatsApp number in international format, digits only (no +, spaces or dashes)
NEXT_PUBLIC_WHATSAPP_NUMBER=5521999999999
NEXT_PUBLIC_WHATSAPP_GREETING=Hi Tim-Luka, I would like to talk about automating my business.

# Contact email
NEXT_PUBLIC_EMAIL_ADDRESS=tim@steelfullai.com

# Social profiles
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/steelfullai
NEXT_PUBLIC_GITHUB_URL=https://github.com/steelfullai
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/steelfullai
