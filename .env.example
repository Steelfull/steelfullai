# Contact configuration — every CTA on the site reads from these values.
# Copy this file to `.env.local` and fill in real values.

# Calendly scheduling link (primary CTA)
NEXT_PUBLIC_CALENDLY_URL=https://calendly.com/steelfullai/strategy-call

# WhatsApp number in international format, digits only (no +, spaces or dashes)
NEXT_PUBLIC_WHATSAPP_NUMBER=5521999999999
NEXT_PUBLIC_WHATSAPP_GREETING=Hi Tim-Luka, I would like to talk about automating my business.

# Contact email
NEXT_PUBLIC_EMAIL_ADDRESS=tim@steelfullai.com

# Social profiles
NEXT_PUBLIC_LINKEDIN_URL=https://www.linkedin.com/in/steelfullai
NEXT_PUBLIC_GITHUB_URL=https://github.com/steelfullai
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/steelfullai

# ─────────────────────────────────────────────────────────────
# AI chatbot (server-side — key never reaches the browser)
# ─────────────────────────────────────────────────────────────
# Anthropic API key. Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx
# Model: Haiku is the right fit for a website assistant (fast + cheap).
# Upgrade to claude-sonnet-4-6 if you ever want more polish.
CHAT_MODEL=claude-haiku-4-5-20251001

# Internal lead-triage briefing agent (runs once per lead — uses a smarter model).
# Produces an internal estimate of scope/effort/difficulty/price for Tim only.
BRIEFING_MODEL=claude-sonnet-4-6
# Optional: also POST each lead + briefing to another agent / n8n / automation.
# LEAD_WEBHOOK_URL=https://your-vps/internal/lead-hook

# ─────────────────────────────────────────────────────────────
# Contact form (server-side — sends each submission to your inbox via SMTP)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.web.de
SMTP_PORT=587
SMTP_SECURE=false                 # true only for port 465
SMTP_USER=tim-luka98@web.de
SMTP_PASS=your-smtp-or-app-password
CONTACT_TO=tim-luka98@web.de      # where leads land (defaults to SMTP_USER)
CONTACT_FROM=SteelfullAI <tim-luka98@web.de>

# ─────────────────────────────────────────────────────────────
# Chat insights dashboard (private, served at /insights)
# ─────────────────────────────────────────────────────────────
# SQLite file path inside the container (mounted on the app_data volume).
INSIGHTS_DB_PATH=/data/chat.sqlite
# Analysis window and raw-data retention, in days.
INSIGHTS_PERIOD_DAYS=90
INSIGHTS_RETENTION_DAYS=90
# Model for the weekly themed analysis (Haiku is plenty).
INSIGHTS_MODEL=claude-haiku-4-5-20251001
# Optional extra guard on POST /api/insights (header x-insights-secret).
# INSIGHTS_TRIGGER_SECRET=

# Basic-auth for the /insights dashboard (enforced by Caddy).
# Generate the bcrypt hash on the VPS:
#   docker run --rm caddy:2-alpine caddy hash-password --plaintext 'YOUR_PASSWORD'
# Put the hash in single quotes in your real .env so the $ signs survive.
INSIGHTS_USER=tim
INSIGHTS_PASSWORD_HASH=
